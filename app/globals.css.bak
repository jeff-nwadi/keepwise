@import "tailwindcss";

/* ─── Color tokens ──────────────────────────────────────────────────────── */
:root {
  /* Editorial paper palette. One warm accent for deadlines, one quiet red for expired. */
  --paper: #faf7f2;        /* page background — warm off-white */
  --paper-2: #f3eee5;      /* card / inset */
  --paper-3: #ece5d6;      /* divider / faint rule */
  --ink: #181715;          /* primary text */
  --ink-2: #4a463f;        /* secondary text */
  --ink-3: #7a756c;        /* tertiary / meta */
  --line: #d9d2c2;         /* hairline borders */
  --amber: #b45309;        /* deadline accent — "act soon" */
  --amber-soft: #f5d28a;   /* amber wash for backgrounds */
  --rose: #9b2c2c;         /* expired — used sparingly */
  --moss: #2f5d3a;         /* covered / healthy */
}

/* ─── Tailwind theme bridge ──────────────────────────────────────────────── */
/* These names match the Next.js CSS variables set on <html> by next/font/google. */
@theme inline {
  --color-paper: var(--paper);
  --color-paper-2: var(--paper-2);
  --color-paper-3: var(--paper-3);
  --color-ink: var(--ink);
  --color-ink-2: var(--ink-2);
  --color-ink-3: var(--ink-3);
  --color-line: var(--line);
  --color-amber: var(--amber);
  --color-amber-soft: var(--amber-soft);
  --color-rose: var(--rose);
  --color-moss: var(--moss);
}

/* ─── Type system ────────────────────────────────────────────────────────── */
/* Reference the Next.js font CSS variables directly. They're set on <html>
 * via the `variable` option in app/layout.tsx (e.g. --font-inter, --font-fraunces,
 * --font-mono). We bind them to Tailwind-friendly names via local CSS vars. */
:root {
  --type-sans: var(--font-inter), ui-sans-serif, system-ui, -apple-system,
    "Segoe UI", sans-serif;
  --type-display: var(--font-fraunces), ui-serif, Georgia, "Times New Roman",
    serif;
  --type-mono: var(--font-mono), ui-monospace, "SF Mono", Menlo, Consolas,
    monospace;
}

body {
  font-family: var(--type-sans);
  font-feature-settings: "ss01", "cv11";
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}

/* Tailwind utility: `font-display` → font-family: var(--type-display). */
.font-display {
  font-family: var(--type-display);
  font-optical-sizing: auto;
  letter-spacing: -0.015em;
}

/* Tailwind utility: `font-mono` needs to also resolve to our mono stack.
 * Tailwind v4 reads `font-mono` from @theme; we override it here to win. */
.font-mono,
code,
kbd,
samp,
pre {
  font-family: var(--type-mono);
}

/* ─── Editorial micro-elements ──────────────────────────────────────────── */
/* Mono eyebrow / labels: small caps feel via uppercase + tracking. */
.eyebrow {
  font-family: var(--type-mono);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

/* ─── Receipt visuals ────────────────────────────────────────────────────── */
/* A torn-edge paper feel for the receipt cards. Pure CSS — no images. */
.receipt {
  background: #fffaf0;
  border: 1px solid var(--line);
  border-radius: 4px;
  box-shadow:
    0 1px 0 rgba(24, 23, 21, 0.04),
    0 8px 24px -12px rgba(24, 23, 21, 0.18);
  font-family: var(--type-mono);
  position: relative;
  overflow: hidden;
}
.receipt::before,
.receipt::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  height: 6px;
  background-image: radial-gradient(circle at 3px 6px, var(--paper) 3px, transparent 3px);
  background-size: 6px 6px;
  background-repeat: repeat-x;
}
.receipt::before { top: -3px; }
.receipt::after { bottom: -3px; }

/* Subtle paper grain — two layered radial gradients. */
.paper-grain {
  background-image:
    radial-gradient(rgba(24, 23, 21, 0.025) 1px, transparent 1px),
    radial-gradient(rgba(24, 23, 21, 0.018) 1px, transparent 1px);
  background-size: 24px 24px, 7px 7px;
  background-position: 0 0, 12px 12px;
}

/* ─── Reduced motion ─────────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
}

/* ─── Focus rings — visible, on-brand ────────────────────────────────────── */
:focus-visible {
  outline: 2px solid var(--amber);
  outline-offset: 2px;
  border-radius: 4px;
}
